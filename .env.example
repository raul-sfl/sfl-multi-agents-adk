# ── AI model ──────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=your_gemini_api_key_here   # Solo en modo AI Studio (sin Vertex AI)

# ── Vertex AI ─────────────────────────────────────────────────────────────────
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west1
# AGENT_ENGINE_LOCATION=europe-west1        # Opcional: región distinta para sesiones

# ── GCP credentials (Railway / Cloud Run) ─────────────────────────────────────
# Paste the full contents of your service account JSON key as a single env var.
# Railway: Settings → Variables → add GOOGLE_APPLICATION_CREDENTIALS_JSON
# Value: the entire JSON ({"type":"service_account","project_id":...})
# Local dev: leave empty and use: gcloud auth application-default login
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# ── Vertex AI Agent Engine — Triage (session storage) ────────────────────────
# Numeric ID del Reasoning Engine del Triage.
# Obtenerlo tras correr: python -m orchestrator.provision
# Si está vacío → InMemorySessionService (sesiones se pierden al reiniciar)
TRIAGE_ENGINE_ID=1234567890123456

# ── Vertex AI Agent Provisioning ─────────────────────────────────────────────
# GCS bucket para staging de artefactos de agentes.
# Solo necesario para: python -m orchestrator.provision
VERTEX_STAGING_BUCKET=gs://your-project-agent-staging

# ── Vertex AI Search (Help Center) ───────────────────────────────────────────
# ID del search engine para el Help Center.
# Obtenerlo en: https://console.cloud.google.com/gen-app-builder/engines
VERTEX_AI_SEARCH_ENGINE_ID=stayforlong-help-center_1234567890

# ── Conversation logging (Cloud Logging) ──────────────────────────────────────
CLOUD_LOGGING_ENABLED=true
CLOUD_LOGGING_LOG_NAME=stayforlong-conversations
HISTORY_RECOVERY_HOURS=48

# ── Admin API ─────────────────────────────────────────────────────────────────
# Bearer token for /admin/api/* — leave empty to disable auth in dev
ADMIN_API_KEY=change-me-in-production

# ── Voice (STT / TTS) ─────────────────────────────────────────────────────────
# Vertex AI Text-to-Speech voice. Leave empty to use the automatic
# per-language default defined in ws/voice_handler.py.
# Full list: https://cloud.google.com/text-to-speech/docs/voices
#
# Quality tiers (best → standard):
#   Chirp3-HD  — most natural, newest generation (auto-uses OGG_OPUS)
#   Neural2    — high quality
#   Studio     — high quality, slower
#   Wavenet    — good quality
#   Standard   — basic
#
# Spanish ES examples:
# TTS_VOICE_NAME=es-ES-Chirp3-HD-Aoede     # femenina ⭐ recomendada
# TTS_VOICE_NAME=es-ES-Chirp3-HD-Kore      # femenina
# TTS_VOICE_NAME=es-ES-Chirp3-HD-Zephyr    # femenina
# TTS_VOICE_NAME=es-ES-Chirp3-HD-Puck      # masculina
# TTS_VOICE_NAME=es-ES-Chirp3-HD-Charon    # masculina
# TTS_VOICE_NAME=es-ES-Neural2-A           # femenina
# TTS_VOICE_NAME=es-ES-Neural2-F           # masculina
# TTS_VOICE_NAME=es-ES-Studio-F            # masculina
#
# Note: Chirp3-HD voices require OGG_OPUS (set automatically by the handler).
#       Neural2/Studio/Wavenet/Standard work with MP3 (default).
#
# TTS_VOICE_NAME=es-ES-Chirp3-HD-Aoede
# TTS_AUDIO_ENCODING=MP3   # MP3 (default) | OGG_OPUS | LINEAR16

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origins allowed to call this API. Leave empty to allow all (dev only).
ADMIN_ORIGIN=https://your-admin-app.netlify.app
FRONTEND_ORIGIN=https://your-chat-widget-cdn.com
